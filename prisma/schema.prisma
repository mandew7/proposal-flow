generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  role         UserRole      @default(USER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sessions     Session[]
  clients      Client[]
  proposals    Proposal[]
  activityLogs ActivityLog[] @relation("ActorActivity")
  targetLogs   ActivityLog[] @relation("TargetActivity")

  @@index([role])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Client {
  id        String     @id @default(cuid())
  userId    String
  name      String
  company   String
  email     String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  proposals Proposal[]

  @@index([userId])
  @@index([email])
}

model Proposal {
  id          String         @id @default(cuid())
  userId      String
  clientId    String?
  publicId    String         @unique @default(cuid())
  title       String
  description String
  amount      Int
  status      ProposalStatus @default(DRAFT)
  dueDate     DateTime
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  client      Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([clientId])
  @@index([status])
  @@index([publicId])
}

model ActivityLog {
  id            String   @id @default(cuid())
  actorUserId   String?
  targetUserId  String?
  action        String
  entityType    String
  entityId      String?
  metadata      String?
  createdAt     DateTime @default(now())
  actorUser     User?    @relation("ActorActivity", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetUser    User?    @relation("TargetActivity", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
}
